# AEGIS-SILENTIUM v12 — Environment Configuration Template
# ============================================================
# Copy to .env and fill ALL required values before starting.
# NEVER commit .env to version control.
# Generate secrets: openssl rand -hex 32
#
# Required variables are marked [REQUIRED]
# Production-only requirements are marked [PROD]
#
# Quick start (development only):
#   export OPERATOR_KEY=$(openssl rand -hex 32)
#   export C2_SECRET=$(openssl rand -hex 32)
#   export POSTGRES_PASSWORD=$(openssl rand -hex 16)
#   docker-compose up
# ============================================================

# ── Authentication [REQUIRED] ─────────────────────────────────────────────────
# Shared operator key — 48+ random chars, used for initial auth.
# Generate: openssl rand -hex 32
OPERATOR_KEY=

# C2 communication secret — must match between C2 and all nodes.
# Generate: openssl rand -hex 32
C2_SECRET=

# JWT signing secret — used for session tokens.
# Generate: openssl rand -hex 48
C2_JWT_SECRET=

# ── Database [REQUIRED] ───────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=

# ── Redis [REQUIRED] ──────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Generate: openssl rand -hex 24
REDIS_PASSWORD=

# ── TLS / HTTPS [PROD] ────────────────────────────────────────────────────────
# Set to 1 in production to enforce HTTPS and HSTS.
REQUIRE_TLS=0
# Path to TLS certificate and key (for gunicorn/nginx)
# TLS_CERT_PATH=/etc/aegis/tls/server.crt
# TLS_KEY_PATH=/etc/aegis/tls/server.key

# ── CORS [PROD] ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. NEVER use *.
# Example: https://your-dashboard.internal,https://c2.your-domain.com
CORS_ALLOWED_ORIGINS=

# ── Network ───────────────────────────────────────────────────────────────────
C2_HOST=0.0.0.0
C2_PORT=7331
C2_URL=http://localhost:7331

# ── Environment tag ───────────────────────────────────────────────────────────
# Set to "production" to enable strict enforcement of all security checks.
# In production mode, missing secrets cause startup failure (sys.exit).
AEGIS_ENV=development

# ── Webhooks [optional] ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=

# ── NVD API [optional] ───────────────────────────────────────────────────────
# Get from: https://nvd.nist.gov/developers/request-an-api-key
# Without this, NVD sync uses the unauthenticated endpoint (rate-limited).
# NVD_API_KEY=

# ── Relay cert pinning [optional] ────────────────────────────────────────────
# SHA-256 fingerprint of the relay server's TLS certificate.
# Get with: openssl s_client -connect relay:443 | openssl x509 -fingerprint -sha256
# AEGIS_RELAY_CERT_HASH=AA:BB:CC:...

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Feature flags ────────────────────────────────────────────────────────────
# Disable features not needed to reduce attack surface.
ENABLE_SURVEILLANCE=true
ENABLE_ZERODAY=true
ENABLE_DISTRIBUTED=true
ENABLE_PERSIST=false
